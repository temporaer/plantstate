{
  "name": "Plant-State",
  "version": "0.1.0",
  "slug": "plant_state",
  "description": "Garden lifecycle planning with weather-based task activation",
  "url": "https://github.com/hannes/plant-state",
  "arch": ["amd64", "aarch64", "armv7"],
  "startup": "application",
  "boot": "auto",
  "ports": {
    "8000/tcp": 8000,
    "80/tcp": 3000
  },
  "ports_description": {
    "8000/tcp": "Backend API",
    "80/tcp": "Web UI"
  },
  "options": {
    "weather_entity": "weather.karlsruhe",
    "calendar_entity": "calendar.garden"
  },
  "schema": {
    "weather_entity": "str",
    "calendar_entity": "str"
  },
  "ingress": true,
  "ingress_port": 80,
  "panel_icon": "mdi:flower",
  "panel_title": "Garden"
}
