# Plant-State environment configuration
# Copy this file to .env and fill in your values

# Home Assistant connection (only needed for standalone mode; add-on uses Supervisor token automatically)
HA_BASE_URL=https://your-ha-instance.local:8123
HA_TOKEN=your_long_lived_access_token_here

# Weather entity (DWD integration recommended)
HA_WEATHER_ENTITY=weather.karlsruhe

# Calendar entity (create via Settings → Integrations → Local Calendar)
HA_CALENDAR_ENTITY=calendar.garden

# Optional: restrict CORS origins (comma-separated, default: * for add-on compatibility)
# CORS_ORIGINS=http://localhost:3000,https://your-ha-instance.local:8123
